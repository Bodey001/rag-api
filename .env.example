# =============================================================================
# RAG API — Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in every value.
# See README.md → Configuration Reference for descriptions and recommended
# values for each variable.
# =============================================================================

# General
VERSION=1.0.0
CONFIG=development
ENV=development

# Internal port that Ollama listens on inside every container.
# Do not change this unless you have a specific reason to.
OLLAMA_DOCKER_PORT=11434

# =============================================================================
# Embedding Model
# Recommended: nomic-embed-text
# See README.md → Configuration Reference → Embedding Model
# =============================================================================
EMBEDDING_MODEL=<ollama-embedding-model-name>
EMBEDDING_LOCAL_PORT=<local-port-to-map-embedding-container>

# for local development (backend running outside Docker):
# EMBEDDING_URL=http://localhost:<EMBEDDING_LOCAL_PORT>
# for Docker environment (backend inside Docker network):
EMBEDDING_URL=http://ollama-nomic-embed-text:${OLLAMA_DOCKER_PORT}


# =============================================================================
# Generation Model
# Recommended: qwen2.5:3b
# See README.md → Configuration Reference → Generation Model
# =============================================================================
GENERATION_MODEL=<ollama-generation-model-name>
GENERATION_LOCAL_PORT=<local-port-to-map-generation-container>

# for local development (backend running outside Docker):
# GENERATION_URL=http://localhost:<GENERATION_LOCAL_PORT>
# for Docker environment (backend inside Docker network):
GENERATION_URL=http://ollama-qwen:${OLLAMA_DOCKER_PORT}


# =============================================================================
# PostgreSQL + pgvector
# See README.md → Configuration Reference → PostgreSQL
# =============================================================================

# Host port exposed to your machine. Use 5433 if 5432 is already taken locally.
POSTGRES_PORT_LOCAL=<host-port-for-postgres>
# Internal container port — PostgreSQL always listens on 5432 inside the container.
POSTGRES_PORT_DOCKER=5432

# Credentials used by both the backend and the pgvector-db container.
POSTGRES_USER=<your-postgres-username>
POSTGRES_PASSWORD=<your-postgres-password>
POSTGRES_DB=<your-postgres-database-name>

# For Docker environment (backend talking to pgvector-db over Docker network):
POSTGRES_PORT=5432
POSTGRES_HOST=pgvector-db

# For local development (backend running outside Docker, connecting via host port):
# POSTGRES_PORT=<POSTGRES_PORT_LOCAL>
# POSTGRES_HOST=localhost


# =============================================================================
# pgAdmin (optional — service is commented out in docker-compose.yml by default)
# See README.md → Configuration Reference → pgAdmin
# =============================================================================
# PGADMIN_DEFAULT_EMAIL=<your-pgadmin-email>
# PGADMIN_DEFAULT_PASSWORD=<your-pgadmin-password>
